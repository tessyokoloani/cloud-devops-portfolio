{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": "ec2:*",
            "Resource":"*"
        },
        {
            "Effect": "Allow",
            "Action": "s3:*",
            "Resource":[
            	"arn:aws:s3:::dev-*/*", 
            	"arn:aws:s3:::dev-*"
        	]
        },
        {
            "Effect": "Allow",
            "Action": ["s3:Get*","s3:List*"],
            "Resource":[
            	"arn:aws:s3:::staging-*/*", 
            	"arn:aws:s3:::staging-*"
        	]
        },
        {
            "Effect": "Deny",
            "Action": "s3:DeleteBucket",
            "Resource":"*"
        },
        {
    	    "Effect": "Deny",
    	    "Action": "s3:*",
	    "Resource": [
		"arn:aws:s3:::prod-*",
		"arn:aws:s3:::prod-*/*"
	    ]
	}
    ]
}
