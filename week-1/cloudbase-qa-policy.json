{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": "ec2:Describe*",
            "Resource":"*"
        },
        {
            "Effect": "Allow",
            "Action": ["s3:GetObject","s3:ListBucket"],
            "Resource":[
            	"arn:aws:s3:::*/*", 
            	"arn:aws:s3:::*"
        	]
        },
        {
    	    "Effect": "Deny",
    	    "Action": "s3:*",
	    "Resource": [
		"arn:aws:s3:::prod-*",
		"arn:aws:s3:::prod-*/*"
	    ]
	}
    ]
}
