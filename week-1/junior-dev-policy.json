{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": [
            	"ec2:DescribeInstances",
            	"ec2:DescribeVpcs",
            	"ec2:DescribeSecurityGroups"
            	],
            "Resource": "*"
        },
        {
            "Effect": "Allow",
            "Action": "s3:GetObject",
            "Resource":"arn:aws:s3:::dev-artifacts-217777498144/*"
        },
        {
            "Effect": "Allow",
            "Action": "s3:ListBucket",
            "Resource":"arn:aws:s3:::dev-artifacts-217777498144"
        }
    ]
}
